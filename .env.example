# --- app ---
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
# Bearer token required on /run and /drift. Leave empty during localhost dev;
# any non-empty value gates every request.
AUTH_TOKEN=
MAX_PROMPT_BYTES=8192
AGENT_MAX_STEPS=8

# --- model client ---
# Provider selection is NOT env-var driven — it's code, in exactly one file:
# src/config/model-client.ts. Edit that file to plug in your provider; this
# MODEL var is just what that file reads by default.
#
# Default (no extra package install): Vercel AI Gateway.
MODEL=anthropic/claude-3-5-sonnet
AI_GATEWAY_API_KEY=

# If you swapped src/config/model-client.ts to a direct provider, uncomment
# the matching key below (only ONE provider package needs to be installed —
# see the comments in that file for the exact swap):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# OPENAI_BASE_URL=http://localhost:11434/v1   # Ollama / vLLM / Together / Groq / ...

# --- telemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agentpulse

# --- drift detector ---
SIGNOZ_URL=http://localhost:8080
SIGNOZ_API_KEY=
# Use built-in fixtures instead of hitting SigNoz — useful for demos or CI
# before you've generated real traffic.
DRIFT_DRY_RUN=0
