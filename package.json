{
  "name": "drift-watch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --import ./dist/telemetry/otel.js ./dist/server.js",
    "dev": "tsx --import ./src/telemetry/otel.ts ./src/server.ts",
    "build": "tsc",
    "drift": "tsx ./src/drift/detector.ts"
  },
  "dependencies": {
    "ai": "^7.0.0",
    "zod": "^3.25.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.55.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.55.0",
    "@opentelemetry/resources": "1.28.0",
    "@opentelemetry/sdk-node": "0.55.0",
    "@opentelemetry/sdk-metrics": "1.28.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "fastify": "^5.1.0"
  },
  "optionalDependencies": {
    "@ai-sdk/openai": "^4.0.0",
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/google": "^4.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
