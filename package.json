{
  "name": "agentpulse-workspace",
  "version": "0.2.0",
  "private": true,
  "description": "Workspace root for AgentPulse: a self-observing AI agent SDK (packages/sdk) and its reference Fastify server (packages/server).",
  "license": "MIT",
  "author": "Victory Lucky",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codewithveek/drift-watch.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.11",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "dev": "pnpm --filter @agentpulse/server dev",
    "start": "pnpm --filter @agentpulse/server start",
    "seed": "pnpm --filter @agentpulse/server seed",
    "drift": "pnpm --filter @agentpulse/server drift",
    "drift:dry-run": "pnpm --filter @agentpulse/server drift:dry-run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
