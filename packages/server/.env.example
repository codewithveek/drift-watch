# --- app ---
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
# Bearer token required on /run and /drift. Leave empty during localhost dev;
# any non-empty value gates every request.
AUTH_TOKEN=
MAX_PROMPT_BYTES=8192
BODY_LIMIT=131072
TRUST_PROXY=0
# Requests allowed per client per window on /run and /drift.
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# --- @driftwatch/sdk config (see packages/sdk/src/config/schema.ts) ---
AGENT_MAX_STEPS=8

# --- model client (Qwen Cloud) ---
# Provider selection is code, in exactly one file:
# packages/server/src/config/model-client.ts. This deployment targets Qwen
# Cloud's OpenAI-compatible endpoint; the vars below feed that file.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
MODEL=qwen-max

# --- telemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=driftwatch
# Set to 0 to stop attaching raw prompt text / tool-call inputs to spans —
# use this if prompts or tool inputs may carry PII/secrets that shouldn't
# land in the tracing backend. Span/metric names and token counts are
# unaffected either way.
OTEL_CAPTURE_PAYLOADS=1

# --- drift detector ---
SIGNOZ_URL=http://localhost:8080
SIGNOZ_API_KEY=
# Use built-in fixtures instead of hitting SigNoz — useful for demos or CI
# before you've generated real traffic.
DRIFT_DRY_RUN=0

# --- inline guardrails (per-request, synchronous — see packages/sdk) ---
# Abort a single agent run once cumulative tokens cross this cap (0 = off).
AGENT_MAX_TOKENS_PER_TASK=0
# Optional USD cap per run, derived from the per-1k-token prices below (0 = off).
AGENT_MAX_COST_USD=0
AGENT_PRICE_PER_1K_INPUT=0
AGENT_PRICE_PER_1K_OUTPUT=0
# What to do when a cap is crossed: stop (halt the loop) | flag (finish, mark it).
AGENT_ON_EXCEED=stop

# --- autopilot (drift-triggered remediation loop) ---
AUTOPILOT_ENABLED=0
# enforce = execute approved actions; shadow = log intended actions only.
AUTOPILOT_MODE=shadow
AUTOPILOT_SCAN_INTERVAL_MS=60000
# Suppress a repeat action for the same signal within this window.
AUTOPILOT_COOLDOWN_MS=300000
# Pending control-action approvals expire to this decision after the timeout.
AUTOPILOT_APPROVAL_TIMEOUT_MS=600000
# Inline JSON policy list, OR point to a file with AUTOPILOT_POLICIES_FILE.
# Example: [{"when":{"severity":"high"},"do":["notify_slack","pause_agent"]}]
AUTOPILOT_POLICIES=
AUTOPILOT_POLICIES_FILE=

# --- shared state (multi-process) ---
# When set, autopilot state (approvals, agent state, history, leader lock)
# lives in Redis so multiple server processes coordinate. Unset = in-memory
# single-process store (fine for dev/demo).
REDIS_URL=

# --- notification channels ---
SLACK_WEBHOOK_URL=
# Signing secret from your Slack app — verifies interactive button callbacks.
SLACK_SIGNING_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Secret token echoed by Telegram on webhook calls (X-Telegram-Bot-Api-Secret-Token).
TELEGRAM_SECRET_TOKEN=
# Generic webhook that receives the raw drift verdict as JSON.
DRIFT_WEBHOOK_URL=
